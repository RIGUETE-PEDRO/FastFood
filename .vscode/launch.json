{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Listen for Xdebug",
      "type": "php",
      "request": "launch",
      "port": 9003,
      "pathMappings": {
        "/app": "c:/Users/omega/Downloads/TCC/FlashFood",
        "/app/": "c:/Users/omega/Downloads/TCC/FlashFood/"
      },
      "serverSourceRoot": "/app",
      "localSourceRoot": "c:/Users/omega/Downloads/TCC/FlashFood",
      "log": true,
      "ignore": [
        "**/vendor/**/*.php"
      ]
    },
    {
      "name": "Debug current PHP file",
      "type": "php",
      "request": "launch",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "runtimeArgs": [
        "-dxdebug.mode=debug",
        "-dxdebug.start_with_request=yes",
        "-dxdebug.client_host=127.0.0.1",
        "-dxdebug.client_port=9003",
        "-dxdebug.idekey=VSCODE"
      ],
      "port": 9003
    },
    {
      "name": "Debug Xdebug smoke test",
      "type": "php",
      "request": "launch",
      "program": "${workspaceFolder}/tools/xdebug-smoke-test.php",
      "cwd": "${workspaceFolder}",
      "runtimeArgs": [
        "-dxdebug.mode=debug",
        "-dxdebug.start_with_request=yes",
        "-dxdebug.client_host=127.0.0.1",
        "-dxdebug.client_port=9003",
        "-dxdebug.idekey=VSCODE"
      ],
      "port": 9003
    }
  ]
}
